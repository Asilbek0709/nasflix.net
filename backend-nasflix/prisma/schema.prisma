generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum ContentType {
  MOVIE
  SERIES
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  password     String?
  name         String?
  avatar       String?
  provider     String?
  refreshToken String?

  role Role @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles       Profile[]
  subscription   Subscription?
  myListEntries  MyListEntry[]
  watchProgress  WatchProgress[]
}

model MyListEntry {
  id      String @id @default(cuid())
  userId  String
  movieId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model WatchProgress {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  progress  Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Profile {
  id     String  @id @default(cuid())
  name   String
  avatar String?
  userId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  history   WatchHistory[]
  favorites Favorite[]
  ratings   Rating[]
}

model Plan {
  id       String       @id @default(cuid())
  name     String       @unique
  tier     String       @default("basic")
  price    Int          @default(0)
  interval PlanInterval @default(MONTHLY)

  createdAt DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id String @id @default(cuid())

  userId String @unique
  planId String

  stripeCustomerId     String?
  stripeSubscriptionId String?

  status SubscriptionStatus @default(CANCELED)

  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])
}

model Content {
  id          String      @id @default(cuid())
  title       String
  description String
  type        ContentType

  releaseYear Int
  duration    Int?
  thumbnail   String
  videoUrl    String

  ageLimit Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  genres  ContentGenre[]
  seasons Season[]

  history   WatchHistory[]
  favorites Favorite[]
  ratings   Rating[]
}

model Genre {
  id   String @id @default(cuid())
  name String @unique

  contents ContentGenre[]
}

model ContentGenre {
  contentId String
  genreId   String

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre   Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
}

model Season {
  id     String @id @default(cuid())
  number Int

  contentId String

  content  Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([contentId, number])
}

model Episode {
  id String @id @default(cuid())

  title       String
  description String
  number      Int

  videoUrl String
  duration Int

  seasonId String

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
}

model WatchHistory {
  id String @id @default(cuid())

  profileId String
  contentId String

  progress Int

  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

model Favorite {
  id String @id @default(cuid())

  profileId String
  contentId String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

model Rating {
  id String @id @default(cuid())

  value Int

  profileId String
  contentId String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}
